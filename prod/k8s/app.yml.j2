# --- POSTGRES DATABASE ---
apiVersion: v1
kind: Service
metadata:
  name: postgres
spec:
  ports:
    - port: 5432
  selector:
    app: postgres
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres
spec:
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      containers:
        - name: postgres
          image: postgres:16
          env:
            - name: POSTGRES_DB
              value: "aneki"
            - name: POSTGRES_USER
              valueFrom:
                secretKeyRef:
                  name: aneki-db
                  key: username
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: aneki-db
                  key: password
          ports:
            - containerPort: 5432
          volumeMounts:
            - name: init-script
              mountPath: /docker-entrypoint-initdb.d
      volumes:
        - name: init-script
          configMap:
            name: postgres-init-config

---
# --- BACKEND SERVICE ---
apiVersion: v1
kind: Service
metadata:
  name: backend
  labels:
    app: backend
spec:
  type: NodePort
  ports:
    - name: http-metrics
      port: 8080
      targetPort: 8080
      nodePort: 30081
  selector:
    app: backend

---
# --- BACKEND DEPLOYMENT ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
spec:
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      imagePullSecrets:
        - name: twc-registry-key
      containers:
        - name: backend
          image: "{{ registry_host }}/prod/aneki-backend:{{ image_tag }}"
          resources:
            requests:
              cpu: "200m"
              memory: "512Mi"
            limits:
              cpu: "800m"
              memory: "1Gi"
          readinessProbe:
            httpGet:
              path: /actuator/health
              port: 8080
            initialDelaySeconds: 40
          env:
            - name: PORT
              value: "8080"
            - name: DB_HOST
              value: "postgres"
            - name: DB_PORT
              value: "5432"
            - name: DB_NAME
              value: "aneki"
            - name: DB_USER
              valueFrom:
                secretKeyRef:
                  name: aneki-db
                  key: username
            - name: DB_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: aneki-db
                  key: password
            - name: JWT_SECRET
              valueFrom:
                secretKeyRef:
                  name: aneki-app
                  key: jwt-secret
          ports:
            - containerPort: 8080

---
# --- HORIZONTAL POD AUTOSCALER (HPA) ---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: backend-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: backend
  minReplicas: 1
  maxReplicas: 5
  metrics:
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: 15

---
# --- SERVICE MONITOR ---
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: backend-monitor
  namespace: monitoring
  labels:
    release: monitoring
spec:
  selector:
    matchLabels:
      app: backend
  namespaceSelector:
    matchNames:
      - default
  endpoints:
  - port: http-metrics
    path: /actuator/prometheus
    interval: 2s

---
# --- GRAFANA DASHBOARD ---
apiVersion: v1
kind: ConfigMap
metadata:
  name: aneki-backend-grafana-dashboard
  namespace: monitoring
  labels:
    grafana_dashboard: "1"
data:
  aneki-backend.json: |
    {
      "title": "Aneki Backend",
      "uid": "aneki-backend",
      "schemaVersion": 39,
      "refresh": "2s",
      "time": {
        "from": "now-5m",
        "to": "now"
      },
      "tags": ["aneki", "backend"],
      "templating": {
        "list": [
          {
            "name": "datasource",
            "label": "Datasource",
            "type": "datasource",
            "hide": 2,
            "query": "prometheus",
            "current": {
              "text": "Prometheus",
              "value": "prometheus"
            }
          },
          {
            "name": "pod",
            "label": "Pod",
            "type": "query",
            "datasource": "${datasource}",
            "query": "label_values(kube_pod_info{pod=~\"backend-.*\"}, pod)",
            "includeAll": true,
            "multi": true,
            "allValue": ".*",
            "current": {
              "text": "All",
              "value": "$__all"
            }
          }
        ]
      },
      "panels": [
        {
          "id": 1,
          "title": "HTTP requests by pod",
          "type": "timeseries",
          "datasource": "${datasource}",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
          "fieldConfig": { "defaults": { "unit": "reqps" } },
          "targets": [
            {
              "expr": "sum by (pod) (rate(http_server_requests_seconds_count{pod=~\"$pod\"}[5m]))",
              "legendFormat": "{{ '{{' }}pod{{ '}}' }}",
              "refId": "A"
            }
          ]
        },
        {
          "id": 2,
          "title": "JVM memory by pod",
          "type": "timeseries",
          "datasource": "${datasource}",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
          "fieldConfig": { "defaults": { "unit": "bytes" } },
          "targets": [
            {
              "expr": "sum by (pod, area) (jvm_memory_used_bytes{pod=~\"$pod\"})",
              "legendFormat": "{{ '{{' }}pod{{ '}}' }} {{ '{{' }}area{{ '}}' }}",
              "refId": "A"
            }
          ]
        },
        {
          "id": 3,
          "title": "Process CPU by pod",
          "type": "timeseries",
          "datasource": "${datasource}",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
          "fieldConfig": { "defaults": { "unit": "percentunit" } },
          "targets": [
            {
              "expr": "sum by (pod) (rate(process_cpu_usage{pod=~\"$pod\"}[5m]))",
              "legendFormat": "{{ '{{' }}pod{{ '}}' }}",
              "refId": "A"
            }
          ]
        }
      ]
    }

---
# --- FRONTEND SERVICE ---
apiVersion: v1
kind: Service
metadata:
  name: frontend
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 80
      targetPort: 80
  selector:
    app: frontend

---
# --- FRONTEND INGRESS ---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: frontend
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: "10m"
spec:
  ingressClassName: nginx
  rules:
    - http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: frontend
                port:
                  number: 80

---
# --- FRONTEND DEPLOYMENT ---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend
spec:
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
    spec:
      imagePullSecrets:
        - name: twc-registry-key
      containers:
        - name: frontend
          image: "{{ registry_host }}/prod/aneki-frontend:{{ image_tag }}"
          ports:
            - containerPort: 80
